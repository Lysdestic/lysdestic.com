---
import LinkNewTab from './LinkNewTab.astro'
// import Email from './Email.astro'
import { Icon } from 'astro-icon/components'
import { contactLinks } from '../../data/contactLinks'

const stardate = import.meta.env.PUBLIC_STARDATE ?? 'dev'

const { linkedIn, github, email, lastfm, facebook } = contactLinks
---

<footer>
    <p>
        Built with <LinkNewTab link="https://astro.build">Astro</LinkNewTab> by Lysdestic
        in
        <LinkNewTab link="https://isportlandburning.com/"
            >Portland, OR</LinkNewTab
        ><br />
        sitrev: {stardate}
    </p>

    <div class="contacts-container">
        <LinkNewTab link={lastfm.link} ariaLabel={lastfm.label}>
            <Icon name="ion:musical-notes" aria-hidden="true" />
        </LinkNewTab>
        <LinkNewTab link={facebook.link} ariaLabel={facebook.label}>
            <Icon name="ion:logo-facebook" aria-hidden="true" />
        </LinkNewTab>
        <LinkNewTab link={github.link} ariaLabel={github.label}>
            <Icon name="ion:logo-github" aria-hidden="true" />
        </LinkNewTab>
        <LinkNewTab link={linkedIn.link} ariaLabel={linkedIn.label}>
            <Icon name="ion:logo-linkedin" aria-hidden="true" />
        </LinkNewTab>
        <LinkNewTab link={email.link} ariaLabel={email.label}>
            <Icon name="ion:mail" aria-hidden="true" />
        </LinkNewTab>
    </div>
</footer>

<style>
    [data-icon] {
        font-size: 2rem;
        color: var(--dark);
    }

    .contacts-container {
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
        font-size: 0;
        height: 2rem;
    }

    footer {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        width: 100%;
        padding: 2rem 0;
        text-align: center;
    }

    footer p {
        display: block;
        width: 80%;
        margin: 0;
        padding-top: 2rem;
        font-size: 0.8rem;
        color: var(--mid);
        line-height: 1.5;
        border-top-color: var(--mid);
        border-top-style: solid;
        border-top-width: 1px;
    }

    @media screen and (min-width: 600px) {
        footer {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
            text-align: left;
        }

        footer p {
            width: 50%;
            padding-top: 0;
            font-size: 1rem;
            font-style: italic;
            border-top-width: 0px;
        }
    }

    @media (prefers-color-scheme: dark) {
        [data-icon] {
            color: var(--light);
        }
    }
</style>
