<button
    class="hamburger"
    id="nav-toggle"
    aria-label="Open navigation menu"
    aria-controls="nav-drawer"
    aria-expanded="false"
>
    <span></span>
    <span></span>
    <span></span>
</button>

<nav class="nav-drawer" id="nav-drawer" aria-hidden="true">
    <button class="nav-close" id="nav-close" aria-label="Close navigation"
        >✕</button
    >
    <div class="nav-links">
        <a href="/">Home</a>
        <a href="/media">Media</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
    </div>
</nav>

<div class="nav-overlay" id="nav-overlay" aria-hidden="true"></div>

<script>
    const toggle = document.getElementById('nav-toggle')
    const drawer = document.getElementById('nav-drawer')
    const overlay = document.getElementById('nav-overlay')
    const close = document.getElementById('nav-close')
    const navLinks = document.querySelectorAll('.nav-links a')

    if (!toggle || !drawer || !overlay || !close) {
        console.warn('Navigation elements not found')
    } else {
        function setOpen(isOpen, opts = { restoreFocus: false }) {
            drawer.classList.toggle('open', isOpen)
            overlay.classList.toggle('open', isOpen)
            document.body.style.overflow = 'hidden'
            if (!isOpen) {
                document.body.style.overflow = ''
            }
            toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false')
            drawer.setAttribute('aria-hidden', isOpen ? 'false' : 'true')
            overlay.setAttribute('aria-hidden', isOpen ? 'false' : 'true')
            if (isOpen) {
                close.focus()
                return
            }
            if (opts.restoreFocus) {
                toggle.focus()
            }
        }

        function shut(opts) {
            setOpen(false, opts ?? { restoreFocus: true })
        }

        function reset() {
            setOpen(false, { restoreFocus: false })
        }

        toggle.addEventListener('click', () => {
            const isOpen = toggle.getAttribute('aria-expanded') === 'true'
            setOpen(!isOpen)
        })
        close.addEventListener('click', () => shut())
        overlay.addEventListener('click', () => shut())
        navLinks.forEach((link) => link.addEventListener('click', () => shut()))
        document.addEventListener('keydown', (event) => {
            const isOpen = toggle.getAttribute('aria-expanded') === 'true'
            if (event.key === 'Escape' && isOpen) {
                shut()
            }
        })
        window.addEventListener('pageshow', reset)
        document.addEventListener('astro:page-load', reset)

        reset()
    }
</script>

<style>
    .hamburger {
        display: flex;
        flex-direction: column;
        gap: 7px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        z-index: 1001;
        position: relative;
    }

    .hamburger span {
        display: block;
        width: 32px;
        height: 2px;
        background-image: linear-gradient(
            90deg,
            hsl(300, 82%, 44%),
            hsl(271, 44%, 63%),
            hsl(202, 84%, 40%)
        );
        background-size: 200% 100%;
        animation: link-underline 20s ease infinite;
        border-radius: 2px;
        transition: opacity 200ms ease;
    }

    .nav-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: min(320px, 80vw);
        height: 100vh;
        background: var(--dark);
        z-index: 1000;
        transform: translateX(100%);
        transition: transform 300ms ease;
        display: flex;
        flex-direction: column;
        padding: 2rem;
        gap: 1rem;
    }

    .nav-drawer.open {
        transform: translateX(0);
    }

    .nav-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 999;
        opacity: 0;
        pointer-events: none;
        transition: opacity 300ms ease;
    }

    .nav-overlay.open {
        opacity: 1;
        pointer-events: all;
    }

    .nav-close {
        background: none;
        border: none;
        color: var(--light);
        font-size: 1.5rem;
        cursor: pointer;
        align-self: flex-end;
        padding: 0;
        line-height: 1;
    }

    .nav-links {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        margin-top: 2rem;
    }

    .nav-links a {
        color: var(--light);
        font-size: 1.5rem;
        font-family: Georgia, Times, 'Times New Roman', serif;
        -webkit-text-fill-color: var(--light);
        text-decoration: none;
        background-image: linear-gradient(
            90deg,
            hsl(300, 50%, 60%),
            hsl(271, 40%, 65%),
            hsl(202, 50%, 60%)
        );
        background-repeat: no-repeat;
        background-position: 0% 100%;
        background-size: 200% 2px;
        animation: link-underline 20s ease infinite;
        padding-bottom: 0.25rem;
    }

    @media (prefers-color-scheme: dark) {
        .nav-drawer {
            background: hsl(257deg 100% 8%);
        }
    }
</style>
