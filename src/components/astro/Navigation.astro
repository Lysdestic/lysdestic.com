<button class="hamburger" id="nav-toggle" aria-label="Toggle navigation">
    <span></span>
    <span></span>
    <span></span>
</button>

<nav class="nav-drawer" id="nav-drawer">
    <button class="nav-close" id="nav-close" aria-label="Close navigation">✕</button>
    <div class="nav-links">
        <a href="/">Home</a>
        <a href="/media">Media</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
    </div>
</nav>

<div class="nav-overlay" id="nav-overlay"></div>

<script>
    const toggle = document.getElementById('nav-toggle')
    const drawer = document.getElementById('nav-drawer')
    const overlay = document.getElementById('nav-overlay')
    const close = document.getElementById('nav-close')

    function open() {
        drawer.classList.add('open')
        overlay.classList.add('open')
        document.body.style.overflow = 'hidden'
    }

    function shut() {
        drawer.classList.remove('open')
        overlay.classList.remove('open')
        document.body.style.overflow = ''
    }

    toggle.addEventListener('click', open)
    close.addEventListener('click', shut)
    overlay.addEventListener('click', shut)
</script>

<style>
    .hamburger {
        display: flex;
        flex-direction: column;
        gap: 7px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        z-index: 1001;
        position: relative;
    }

    .hamburger span {
        display: block;
        width: 32px;
        height: 2px;
        background-image: linear-gradient(
            90deg,
            hsl(300, 82%, 44%),
            hsl(271, 44%, 63%),
            hsl(202, 84%, 40%)
        );
        background-size: 200% 100%;
        animation: link-underline 20s ease infinite;
        border-radius: 2px;
        transition: opacity 200ms ease;
    }

    .nav-drawer {
        position: fixed;
        top: 0;
        right: 0;
        width: min(320px, 80vw);
        height: 100vh;
        background: var(--dark);
        z-index: 1000;
        transform: translateX(100%);
        transition: transform 300ms ease;
        display: flex;
        flex-direction: column;
        padding: 2rem;
        gap: 1rem;
    }

    .nav-drawer.open {
        transform: translateX(0);
    }

    .nav-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 999;
        opacity: 0;
        pointer-events: none;
        transition: opacity 300ms ease;
    }

    .nav-overlay.open {
        opacity: 1;
        pointer-events: all;
    }

    .nav-close {
        background: none;
        border: none;
        color: var(--light);
        font-size: 1.5rem;
        cursor: pointer;
        align-self: flex-end;
        padding: 0;
        line-height: 1;
    }

    .nav-links {
        display: flex;
