---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)
---

<Layout includeHeading subtitle="Blog">
    <section id="blog">
        <article class="gradient-container">
            <p>Random musings. Infrequent updates.</p>
            <ul class="post-list">
                {
                    posts.map((post) => (
                        <li>
                            <a href={`/blog/${post.id}`}>{post.data.title}</a>
                            <time datetime={post.data.date.toISOString()}>
                                {post.data.date.toLocaleDateString('en-US', {
                                    year: 'numeric',
                                    month: 'long',
                                    day: 'numeric',
                                })}
                            </time>
                            <p>{post.data.description}</p>
                        </li>
                    ))
                }
            </ul>
        </article>
    </section>
</Layout>

<style>
    .post-list {
        list-style: none;
        padding: 0;
        margin: 1rem 0;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .post-list li {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .post-list a {
        font-family: Georgia, Times, 'Times New Roman', serif;
        font-size: 1.3rem;
        -webkit-text-fill-color: unset;
    }

    time {
        font-size: 0.85rem;
        color: var(--mid);
        -webkit-text-fill-color: unset;
    }

    .post-list p {
        margin: 0;
        font-size: 0.95rem;
        font-style: italic;
        -webkit-text-fill-color: unset;
    }
</style>
